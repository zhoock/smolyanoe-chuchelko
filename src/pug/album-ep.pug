//- album-ep.pug

extends layout.pug

block head
    - var title = 'Смоляное чучелко';
    - var description = 'Официальный сайт Смоляное чучелко';
    - var keywords = 'Гранж, пост-гранж, альтернативный рок, альтернатива, grunge, post-grunge, гранж жив, последний поршневый бомбардировщик, водянистая влага, рулевой мёртв, бром и сталь, падение кита';

    include ../includes/_head
    
    
block content

    section#b-music.js-section
        article
            .row
                .small-9.small-centered.small-only-text-center.column
                    .row
                        .small-12.small-centered.medium-uncentered.medium-5.medium-push-7.column                                
                            .b-wrapper-cover
                                
                                - var pic = 1
                                include ../includes/_picture
                                      
                            .b-share.js-share-item
                                ul
                                    li: a(href="", title="Поделиться").icon-share
                                    li: a(href="", title="Поделиться на Facebook").icon-facebook1
                                    li: a(href="", title="Поделиться на Twitter").icon-twitter

                                              
                        .small-12.medium-7.medium-pull-5.column                               
                            h2 Смоляное чучелко
                            h3 Треки
                            ol.small-text-left
                                li: a(href="/the_last_piston_bomber.html") Последний поршневый бомбардировщик
                                li: a(href="/watery_moisture.html") Водянистая влага
                                li: a(href="/helmsman_dead.html") Рулевой мёртв
                                li: a(href="/bromine_and_steel.html") Бром и сталь
                                li: a(href="/whale_falling.html") Падение кита

                    include ../includes/_distribution



    section#b-album-details.js-section
        article
            .row
                .small-9.small-centered.small-only-text-center.column
                    .row
                        .small-12.medium-4.medium-push-8.column
                            .b-album-details__released
                                h2 Релиз
                                time 16/04/2020

                            .b-album-details__artwork
                                h2 Обложка альбома
                                h3 Дизайн
                                p Blexbolex

                        .small-12.medium-8.medium-pull-4.column
                            .b-album-details__music
                                h2 Запись
                                h3 Жанр
                                ul
                                    li Гранж, альтернативный рок.
                                h3 Запись
                                ul
                                    li 16 октября—28 декабря 2018 (Музыкальная Академия Матвиенко М.А.М.А, Москва).
                                    li 2 ноября 2018 (Продюсерский центр Алексея Мускатина, Москва).
                                    li 4 октября 2019 (Студия Космос, Москва).
                                    li 9 октября 2019—14 декабря 2019 (495 Studio Records, Москва).

                                h3 Сведение
                                ul

                                    li 15 декабря 2019—2 марта 2020 (DTH Studios, Москва).
                                h3 Мастеринг
                                ul
                                    li 31 марта 2020—10 апреля 2020 (Chicago Mastering Service, Chicago, USA).

                                h3 Исполнители
                                ul 
                                    li Ярослав Жук — гитара, вокал, бэк-вокал, слова и музыка.
                                    li Семён Лепёшкин — бас-гитара.

                                h3 Сессионные музыканты
                                ul
                                    li Алексей Еживич — ударные.
                                    li Наталья Хмелёвская — виолончель («Водянистая влага»).

                                h3 Продюсирование
                                ul 
                                    li Жук Ярослав — продюсер.
                                    li Илья Лукашев — звукоинженер.
                                    li Юрий Катешев — звукоинженер (запись виолончели).
                                    li Антон Артисюк — звукоинженер (запись акустической гитары).
                                    li Александр Колесников — звукоинженер (запись вокала).
                                    li Илья Marvel Горохводатский — сведение.
                                    li Mettew J Barnhart — мастеринг.

                                h3 Эта запись была бы невозможна без:
                                p Галина Жук, Аркадий Жук, Кристина Шпак, Сергей Рябов, Илья Быков, Антон Сапфиров, Стив Альбини, Курт Кобейн.                                


                                                       
