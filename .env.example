# =============================================================================
# Environment variables for local dev, Netlify build, and Netlify Functions.
# Copy to `.env` / `.env.local` and fill in secrets (never commit real secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required for Netlify Functions: albums, articles, auth, payments…)
# -----------------------------------------------------------------------------
# PostgreSQL (server-side). For Supabase serverless prefer Transaction pooler (port 6543).
# PG_POOL_MAX caps connections per Node process (shared across all Netlify function bundles).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/POSTGRES
# PG_POOL_MAX=2

# -----------------------------------------------------------------------------
# Auth (JWT for /api/auth and protected functions)
# -----------------------------------------------------------------------------
# REQUIRED. netlify/functions/lib/jwt.ts throws on missing/empty value — there
# is no insecure fallback. Use a long random string (≥ 32 chars), e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Supabase — browser / Webpack (prefix VITE_ is injected in webpack.common.js)
# -----------------------------------------------------------------------------
# Public project URL (non-secret). This repo uses project ref jhpvetvfnsklpwswadle
# in docs and .env.local.example — confirm in your Supabase Dashboard → Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon (public) key — safe for frontend.
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE_STORAGE=false

# -----------------------------------------------------------------------------
# Supabase — Netlify Functions (server)
# Service role must NEVER use the VITE_ prefix (never bundle it for the browser).
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket (netlify/functions/lib/supabase.ts)
STORAGE_BUCKET_NAME=user-media

# -----------------------------------------------------------------------------
# Encryption (netlify/functions/lib/crypto.ts)
# -----------------------------------------------------------------------------
# REQUIRED. Used to encrypt/decrypt seller YooKassa secrets in DB
# (user_payment_settings.secret_key_encrypted). crypto.ts throws on missing/empty
# value — there is no insecure fallback. Generate a fresh key with:
#   openssl rand -base64 48
# WARNING: changing this value after data was encrypted will make existing
# encrypted secrets unreadable. Keep it stable; rotate via re-encryption.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Email (netlify/functions/lib/email.ts)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# Optional display name in transactional emails (default: Mixer)
# SITE_DISPLAY_NAME=Mixer
# SUPPORT_EMAIL=feedback@smolyanoechuchelko.ru

# -----------------------------------------------------------------------------
# Site URL (emails, absolute links, server-side origin fallbacks)
# Netlify sets URL to http://localhost:8888 in dev — use PUBLIC_APP_URL for browser links.
# PUBLIC_APP_URL=http://localhost:8080
NETLIFY_SITE_URL=https://your-site.netlify.app

# Local Netlify CLI / hybrid dev (optional)
# NETLIFY_DEV=true

# -----------------------------------------------------------------------------
# YooKassa
# Album sales: shopId + secret per artist in DB (user_payment_settings).
# Premium subscriptions: YOOKASSA_SHOP_ID + YOOKASSA_SECRET_KEY below.
# -----------------------------------------------------------------------------
YOOKASSA_API_URL=https://api.yookassa.ru/v3/payments
YOOKASSA_RETURN_URL=
YOOKASSA_TEST_MODE=false
SKIP_YOOKASSA_VALIDATION=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# -----------------------------------------------------------------------------
# Premium subscription dev mock (optional, on top of subscriptions table)
# MOCK_ACTIVE_SUBSCRIPTION_USER_IDS=
# MOCK_SUBSCRIPTION_USER_ARTIST_PAIRS=

# -----------------------------------------------------------------------------
# GitHub (optional: exporting site JSON from albums function)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_OWNER=zhoock
GITHUB_REPO=smolyanoe-chuchelko
GITHUB_BRANCH=main

# -----------------------------------------------------------------------------
# Optional: local tooling only (seen in some dev .env.local setups — not required by app)
# -----------------------------------------------------------------------------
# DATABASE_URL_STAGING=
# NETLIFY_STAGING_URL=
# USE_PROD_API=

# -----------------------------------------------------------------------------
# Optional: maintenance scripts (scripts/*.ts)
# -----------------------------------------------------------------------------
# CURRENT_USER_ID=zhoock

# -----------------------------------------------------------------------------
# Node (set by tooling; rarely needed in .env)
# -----------------------------------------------------------------------------
# NODE_ENV=development
