# =============================================================================
# Environment variables for local dev, Netlify build, and Netlify Functions.
# Copy to `.env` / `.env.local` and fill in secrets (never commit real secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required for Netlify Functions: albums, articles, auth, payments…)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/POSTGRES

# -----------------------------------------------------------------------------
# Auth (JWT for /api/auth and protected functions)
# -----------------------------------------------------------------------------
# If unset, netlify/functions/lib/jwt.ts falls back to dev-only string (unsafe).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Supabase — browser / Webpack (prefix VITE_ is injected in webpack.common.js)
# -----------------------------------------------------------------------------
# Public project URL (non-secret). This repo uses project ref jhpvetvfnsklpwswadle
# in docs and .env.local.example — confirm in your Supabase Dashboard → Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon (public) key — safe for frontend.
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE_STORAGE=false

# -----------------------------------------------------------------------------
# Supabase — Netlify Functions (server)
# Service role must NEVER use the VITE_ prefix (never bundle it for the browser).
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket (netlify/functions/lib/supabase.ts)
STORAGE_BUCKET_NAME=user-media

# -----------------------------------------------------------------------------
# Encryption (netlify/functions/lib/crypto.ts)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Email (netlify/functions/lib/email.ts)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Site URL (emails, absolute links, server-side origin fallbacks)
# Netlify sets this automatically in many setups; override if needed.
# -----------------------------------------------------------------------------
NETLIFY_SITE_URL=https://your-site.netlify.app

# Local Netlify CLI / hybrid dev (optional)
# NETLIFY_DEV=true

# -----------------------------------------------------------------------------
# YooKassa (payments)
# -----------------------------------------------------------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3/payments
YOOKASSA_RETURN_URL=
YOOKASSA_TEST_MODE=false
SKIP_YOOKASSA_VALIDATION=false

# -----------------------------------------------------------------------------
# GitHub (optional: exporting site JSON from albums function)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_OWNER=zhoock
GITHUB_REPO=smolyanoe-chuchelko
GITHUB_BRANCH=main

# -----------------------------------------------------------------------------
# Optional: local tooling only (seen in some dev .env.local setups — not required by app)
# -----------------------------------------------------------------------------
# DATABASE_URL_STAGING=
# NETLIFY_STAGING_URL=
# USE_PROD_API=

# -----------------------------------------------------------------------------
# Optional: maintenance scripts (scripts/*.ts)
# -----------------------------------------------------------------------------
# CURRENT_USER_ID=zhoock

# -----------------------------------------------------------------------------
# Node (set by tooling; rarely needed in .env)
# -----------------------------------------------------------------------------
# NODE_ENV=development
